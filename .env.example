# ============================================================
# KAIROS CONFIGURATION
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# SYSTEM
EXECUTION_MODE=PAPER        # PAPER | LIVE  (ALWAYS start as PAPER)
ACTIVE_MARKET=INDIA         # INDIA | US | BOTH
LOG_LEVEL=INFO
DB_PATH=database/kairos.db
LOG_PATH=logs/kairos.log

# CAPITAL
STARTING_CAPITAL_INR=10000
STARTING_CAPITAL_USD=100

# ZERODHA (India — Phase 1)
ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here
ZERODHA_ACCESS_TOKEN=auto_generated_daily

# ALPACA (US — Phase 2)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# OANDA (FX — Phase 3)
OANDA_API_KEY=your_api_key_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_ENVIRONMENT=practice    # practice | live

# RISK (overrides defaults in risk.py if set)
MAX_RISK_PER_TRADE_PCT=0.02
MAX_PORTFOLIO_HEAT_PCT=0.10
DAILY_LOSS_LIMIT_PCT=0.05
MAX_DRAWDOWN_HALT_PCT=0.20

# NOTIFICATIONS (optional)
ALERT_EMAIL=your_email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# AI ASSISTANT (optional — for in-dashboard AI help, not yet built)
ANTHROPIC_API_KEY=your_api_key_here
GEMINI_API_KEY=your_api_key_here
OPENAI_API_KEY=your_api_key_here
